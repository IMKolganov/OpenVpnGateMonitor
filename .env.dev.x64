# ASP.NET environment (Development / Production)
ASPNETCORE_ENVIRONMENT=Development
TARGETARCH=x64
BUILD_CONFIGURATION=Debug

# Database connection string
DB_CONNECTION_STRING_DATAGATE=Host=postgres_backend;Port=5432;Database=datagate_backend;Username=backend_user;Password=securepassword_backend

# JWT secret
JWT_SECRET=super-secret-key-should-be-at-least-16-characters
Jwt__RefreshPepper=your-refresh-pepper

# Frontend -> Backend URL
BACKEND_URL=http://backend:5581
VITE_GOOGLE_CLIENT_ID=your-google-cliend-id

#Google auth
GoogleAuth__ClientId=your-google-cliend-id
GoogleAuth__DesktopClientId=your-desktop-google-cliend-id
GoogleAuth__DesktopClientSecret=your-desktop-google-secret
GoogleAuth__IosClientId=your-google-ios-cliend-id

# Elasticsearch config
ELASTIC_URI=http://elasticsearch:9200
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=your-password
ELASTIC_INDEX_FORMAT=OpenVPNGateMonitor-dev-logs-{0:yyyy.MM.dd}